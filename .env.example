# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_APP_TOKEN=xapp-...

# LLM
LLM_PROVIDER=anthropic
# LLM_MODEL=               # optional: provider 기본 모델 오버라이드
ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...        # provider=gemini 사용 시
# GROQ_API_KEY=gsk_...      # provider=groq 사용 시

# Channel IDs (Slack)
LIFE_CHANNEL_ID=C...

# Cron (Life) — 7슬롯 (모두 optional, 아래는 기본값)
# LIFE_CRON_SLEEP_CHECK=50 8 * * *
# LIFE_CRON_MORNING_SCHEDULE=0 9 * * *
# LIFE_CRON_MORNING=5 9 * * *
# LIFE_CRON_LUNCH=0 13 * * *
# LIFE_CRON_EVENING=0 18 * * *
# LIFE_CRON_NIGHT=0 22 * * *
# LIFE_CRON_NIGHT_REVIEW=0 23 * * *

# Database (PostgreSQL)
# Docker: postgresql://agent:agent_password@db:5432/slack_ai_agents
# Local:  postgresql://agent:agent_password@localhost:5432/slack_ai_agents
DATABASE_URL=postgresql://agent:agent_password@db:5432/slack_ai_agents
