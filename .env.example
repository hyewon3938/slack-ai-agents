# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_APP_TOKEN=xapp-...

# LLM
LLM_PROVIDER=anthropic
# LLM_MODEL=               # optional: provider 기본 모델 오버라이드
ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...        # provider=gemini 사용 시 / 크론 메시지 생성용
# GROQ_API_KEY=gsk_...      # provider=groq 사용 시

# Channel IDs (Slack)
LIFE_CHANNEL_ID=C...
# PROJECT_CHANNEL_ID=C...   # optional: 프로젝트 채널
# INSIGHT_CHANNEL_ID=C...   # optional: 명리학 일운 + 일기 채널

# Database (PostgreSQL)
# VM: Docker 내부 연결 (db 서비스명)
DATABASE_URL=postgresql://agent:PASSWORD@db:5432/slack_ai_agents
POSTGRES_PASSWORD=...              # docker-compose PostgreSQL 비밀번호

# Web Dashboard (Vercel 환경변수로 설정)
# SESSION_SECRET=...              # 세션 암호화 키 (32자+ hex)
# BYPASS_AUTH=true                # 로컬 개발용 인증 바이패스 (userId=1로 통과)

# Kakao OAuth (Vercel 환경변수로 설정)
# KAKAO_CLIENT_ID=...             # Kakao REST API 키
# NEXT_PUBLIC_KAKAO_CLIENT_ID=... # 클라이언트용 (KAKAO_CLIENT_ID와 동일 값)
# KAKAO_CLIENT_SECRET=...         # optional: Kakao 보안 설정 시
