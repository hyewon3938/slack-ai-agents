# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_APP_TOKEN=xapp-...

# LLM
LLM_PROVIDER=anthropic
# LLM_MODEL=               # optional: provider 기본 모델 오버라이드
ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...        # provider=gemini 사용 시 / 크론 메시지 생성용
# GROQ_API_KEY=gsk_...      # provider=groq 사용 시

# Channel IDs (Slack)
LIFE_CHANNEL_ID=C...
# PROJECT_CHANNEL_ID=C...   # optional: 프로젝트 채널

# Database (PostgreSQL)
# Docker: postgresql://agent:REDACTED_PASSWORD@db:5432/slack_ai_agents
# Local:  postgresql://agent:REDACTED_PASSWORD@localhost:5432/slack_ai_agents
DATABASE_URL=postgresql://agent:REDACTED_PASSWORD@db:5432/slack_ai_agents
