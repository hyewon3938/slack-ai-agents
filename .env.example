# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_APP_TOKEN=xapp-...

# LLM
LLM_PROVIDER=gemini
# LLM_MODEL=               # optional: provider 기본 모델 오버라이드
GEMINI_API_KEY=...
# GROQ_API_KEY=gsk_...
# ANTHROPIC_API_KEY=sk-ant-...

# Notion
NOTION_API_KEY=ntn_...
NOTION_SCHEDULE_DB_ID=...
NOTION_ROUTINE_DB_ID=...
NOTION_SLEEP_DB_ID=...

# Channel IDs (Slack)
SCHEDULE_CHANNEL_ID=C...
ROUTINE_CHANNEL_ID=C...
# LIFE_CHANNEL_ID=C...          # v2: 통합 에이전트 채널

# Cron (Schedule)
CRON_MORNING=0 9 * * *
CRON_LUNCH=0 13 * * *
CRON_EVENING=0 18 * * *
CRON_NIGHT=0 23 * * *

# Cron (Routine)
CRON_ROUTINE_MORNING=0 9 * * *
CRON_ROUTINE_LUNCH=0 13 * * *
CRON_ROUTINE_EVENING=0 18 * * *
CRON_ROUTINE_NIGHT=0 22 * * *

# Database (PostgreSQL)
# Docker: postgresql://agent:agent_password@db:5432/slack_ai_agents
# Local:  postgresql://agent:agent_password@localhost:5432/slack_ai_agents
DATABASE_URL=postgresql://agent:agent_password@db:5432/slack_ai_agents
